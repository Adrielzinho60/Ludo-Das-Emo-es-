<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Painel · Ludo das Emoções</title>
<style>
  * { box-sizing: border-box; margin:0; padding:0; font-family:'Segoe UI', system-ui, sans-serif; }
  body {
    min-height:100vh; color:#fff;
    background: linear-gradient(135deg,#1a1a3e,#2d1b4e,#1a1a3e);
    background-size: 200% 200%;
    animation: bgShift 18s ease infinite;
    padding: 20px;
  }
  @keyframes bgShift { 0%{background-position:0% 0%} 50%{background-position:100% 100%} 100%{background-position:0% 0%} }

  header { max-width:720px; margin:0 auto 18px; text-align:center; animation: fadeDown .5s ease; }
  @keyframes fadeDown { from{opacity:0; transform:translateY(-12px)} to{opacity:1; transform:translateY(0)} }
  h1 { font-size:clamp(1.6rem,5vw,2.2rem); background:linear-gradient(90deg,#ff6b6b,#feca57,#48dbfb,#1dd1a1); -webkit-background-clip:text; background-clip:text; color:transparent; }
  header p { color:#a0a0c0; margin-top:6px; font-size:.9rem; }

  .status-row { display:flex; align-items:center; justify-content:center; gap:8px; margin-top:10px; font-size:.8rem; color:#a0a0c0; }
  .status-dot { width:9px; height:9px; border-radius:50%; background:#888; transition:.3s; }
  .status-dot.ok { background:#1dd1a1; box-shadow:0 0 8px #1dd1a1; }
  .status-dot.err { background:#ff6b6b; box-shadow:0 0 8px #ff6b6b; }

  .wrap { max-width:720px; margin:0 auto; }

  .card { background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1); border-radius:16px; padding:18px; margin-bottom:16px; animation: fadeUp .45s ease; }
  @keyframes fadeUp { from{opacity:0; transform:translateY(10px)} to{opacity:1; transform:translateY(0)} }

  details.card summary { cursor:pointer; font-weight:700; list-style:none; display:flex; align-items:center; gap:8px; }
  details.card summary::-webkit-details-marker { display:none; }
  details.card summary .chev { transition: transform .25s ease; font-size:.8rem; color:#a0a0c0; margin-left:auto; }
  details.card[open] summary .chev { transform: rotate(90deg); }

  .field { margin-top:12px; }
  .field label { display:block; font-size:.78rem; color:#a0a0c0; margin-bottom:5px; }
  input[type=text], input[type=password], textarea, select {
    width:100%; padding:10px 12px; border-radius:10px; border:1px solid rgba(255,255,255,.18);
    background:rgba(255,255,255,.05); color:#fff; font-size:.92rem; outline:none; transition:.2s;
  }
  input::placeholder, textarea::placeholder { color:#6e6e95; }
  input:focus, textarea:focus, select:focus { border-color:#48dbfb; box-shadow:0 0 0 3px rgba(72,219,251,.18); }
  textarea { resize:vertical; min-height:64px; }

  .btn { border:none; border-radius:10px; padding:10px 16px; font-weight:700; cursor:pointer; transition:transform .12s, box-shadow .2s; font-size:.9rem; }
  .btn:active { transform: scale(.96); }
  .btn-primary { background:linear-gradient(135deg,#6c5ce7,#a29bfe); color:#fff; box-shadow:0 4px 16px rgba(108,92,231,.4); }
  .btn-primary:hover { box-shadow:0 6px 22px rgba(108,92,231,.55); }
  .btn-ghost { background:rgba(255,255,255,.08); color:#fff; border:1px solid rgba(255,255,255,.15); }
  .btn-danger { background:rgba(255,107,107,.15); color:#ff9b9b; border:1px solid rgba(255,107,107,.3); padding:6px 10px; font-size:.8rem; }
  .btn-danger:hover { background:rgba(255,107,107,.28); }
  .btn-row { display:flex; gap:10px; margin-top:14px; flex-wrap:wrap; }

  /* Tabs */
  .tabs { display:flex; gap:6px; background:rgba(255,255,255,.05); border-radius:14px; padding:5px; margin-bottom:16px; position:relative; }
  .tab { flex:1; text-align:center; padding:10px 6px; border-radius:10px; cursor:pointer; font-weight:700; font-size:.85rem; color:#a0a0c0; transition:color .2s; position:relative; z-index:1; user-select:none; }
  .tab.active { color:#1a1a3e; }
  .tab-indicator { position:absolute; top:5px; left:5px; height:calc(100% - 10px); border-radius:10px; background:linear-gradient(135deg,#feca57,#ff9f43); transition: left .25s ease, width .25s ease; z-index:0; }

  .panel { display:none; }
  .panel.active { display:block; animation: fadeUp .3s ease; }

  .list { display:flex; flex-direction:column; gap:8px; margin-top:14px; }
  .item { background:rgba(255,255,255,.05); border-radius:10px; padding:10px 12px; display:flex; align-items:flex-start; gap:10px; justify-content:space-between; transition: all .25s ease; }
  .item.removing { opacity:0; transform: scale(.92) translateX(8px); }
  .item .txt { font-size:.88rem; line-height:1.4; color:#e8e8f5; }
  .item .txt small { display:block; color:#8888ad; font-size:.74rem; margin-top:3px; }
  .empty-hint { color:#7d7da3; font-size:.85rem; text-align:center; padding:18px 0; }

  .opts-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:10px; }
  .correct-row { display:flex; gap:8px; margin-top:10px; flex-wrap:wrap; }
  .correct-chip { padding:6px 12px; border-radius:20px; border:1px solid rgba(255,255,255,.2); cursor:pointer; font-size:.8rem; color:#cfcfe6; transition:.2s; }
  .correct-chip.sel { background:#1dd1a1; color:#0c2b22; border-color:#1dd1a1; font-weight:700; }

  .publish-bar { position:sticky; bottom:14px; display:flex; justify-content:center; margin-top:20px; }
  .publish-btn { padding:14px 26px; border-radius:50px; background:linear-gradient(135deg,#1dd1a1,#10ac84); color:#fff; font-weight:800; border:none; cursor:pointer; box-shadow:0 8px 28px rgba(29,209,161,.45); display:flex; align-items:center; gap:10px; font-size:.95rem; }
  .publish-btn:disabled { opacity:.6; cursor:not-allowed; }
  .spin { width:16px; height:16px; border:2px solid rgba(255,255,255,.4); border-top-color:#fff; border-radius:50%; animation: spin .7s linear infinite; display:none; }
  .spin.show { display:inline-block; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .toast-area { position:fixed; top:16px; right:16px; display:flex; flex-direction:column; gap:8px; z-index:300; }
  .toast { background:#1a1a3e; border:1px solid rgba(255,255,255,.15); padding:12px 16px; border-radius:12px; font-size:.85rem; box-shadow:0 8px 24px rgba(0,0,0,.4); animation: toastIn .25s ease, toastOut .25s ease 2.6s forwards; max-width:280px; }
  .toast.ok { border-color:#1dd1a1; }
  .toast.err { border-color:#ff6b6b; }
  @keyframes toastIn { from{opacity:0; transform:translateX(30px)} to{opacity:1; transform:translateX(0)} }
  @keyframes toastOut { to{opacity:0; transform:translateX(30px)} }

  footer { text-align:center; color:#5f5f87; font-size:.75rem; margin-top:28px; padding-bottom:30px; }
</style>
</head>
<body>

<div class="toast-area" id="toastArea"></div>

<header>
  <h1>Painel · Ludo das Emoções</h1>
  <p>Adicione, edite ou remova o conteúdo do jogo sem tocar em código.</p>
  <div class="status-row">
    <span class="status-dot" id="statusDot"></span>
    <span id="statusText">Verificando conexão com o GitHub…</span>
  </div>
</header>

<div class="wrap">

  <details class="card" id="settingsCard">
    <summary>⚙️ Configuração do repositório <span class="chev">▸</span></summary>
    <div class="field">
      <label>Usuário do GitHub</label>
      <input type="text" id="cfgOwner" placeholder="ex: Adrielzinho60">
    </div>
    <div class="field">
      <label>Repositório</label>
      <input type="text" id="cfgRepo" placeholder="ex: Ludo-Das-Emo-es-">
    </div>
    <div class="field">
      <label>Branch</label>
      <input type="text" id="cfgBranch" placeholder="main" value="main">
    </div>
    <div class="field">
      <label>Token (fine-grained, escopo Contents: Read and write)</label>
      <input type="password" id="cfgToken" placeholder="github_pat_...">
    </div>
    <div class="btn-row">
      <button class="btn btn-primary" onclick="salvarConfig()">Salvar e conectar</button>
      <button class="btn btn-ghost" onclick="limparConfig()">Limpar dados salvos</button>
    </div>
  </details>

  <div class="tabs" id="tabs">
    <div class="tab-indicator" id="tabIndicator"></div>
    <div class="tab active" data-tab="curio">💡 Curiosidades</div>
    <div class="tab" data-tab="quest">❓ Perguntas</div>
    <div class="tab" data-tab="rem">🗑️ Remover</div>
  </div>

  <!-- CURIOSIDADES -->
  <div class="panel active" id="panel-curio">
    <div class="card">
      <div class="field">
        <label>Nova curiosidade</label>
        <textarea id="novaCuriosidade" placeholder="Ex: Sorrir, mesmo forçado, libera endorfinas."></textarea>
      </div>
      <div class="btn-row"><button class="btn btn-primary" onclick="addCuriosidade()">Adicionar à lista</button></div>
    </div>
    <div class="card">
      <strong>Curiosidades extras (<span id="countCurio">0</span>)</strong>
      <div class="list" id="listCuriosidades"></div>
    </div>
  </div>

  <!-- PERGUNTAS -->
  <div class="panel" id="panel-quest">
    <div class="card">
      <div class="field">
        <label>Pergunta</label>
        <input type="text" id="novaPergunta" placeholder="Ex: Qual é o hormônio do amor?">
      </div>
      <div class="opts-grid">
        <div class="field"><label>Opção 1</label><input type="text" id="op1"></div>
        <div class="field"><label>Opção 2</label><input type="text" id="op2"></div>
        <div class="field"><label>Opção 3</label><input type="text" id="op3"></div>
        <div class="field"><label>Opção 4</label><input type="text" id="op4"></div>
      </div>
      <div class="field">
        <label>Qual é a correta?</label>
        <div class="correct-row" id="correctRow">
          <div class="correct-chip" data-c="0">Opção 1</div>
          <div class="correct-chip" data-c="1">Opção 2</div>
          <div class="correct-chip" data-c="2">Opção 3</div>
          <div class="correct-chip" data-c="3">Opção 4</div>
        </div>
      </div>
      <div class="btn-row"><button class="btn btn-primary" onclick="addPergunta()">Adicionar à lista</button></div>
    </div>
    <div class="card">
      <strong>Perguntas extras (<span id="countQuest">0</span>)</strong>
      <div class="list" id="listPerguntas"></div>
    </div>
  </div>

  <!-- REMOVER -->
  <div class="panel" id="panel-rem">
    <div class="card">
      <div class="field">
        <label>Texto exato a esconder do jogo</label>
        <textarea id="novaRemovida" placeholder="Cole aqui o texto EXATO de uma curiosidade ou pergunta (fixa ou extra) que você quer esconder."></textarea>
      </div>
      <div class="btn-row"><button class="btn btn-primary" onclick="addRemovida()">Adicionar à lista de removidas</button></div>
    </div>
    <div class="card">
      <strong>Itens escondidos (<span id="countRem">0</span>)</strong>
      <div class="list" id="listRemovidas"></div>
    </div>
  </div>

  <div class="publish-bar">
    <button class="publish-btn" id="publishBtn" onclick="publicar()">
      <span class="spin" id="publishSpin"></span>
      <span id="publishLabel">🚀 Publicar atualização</span>
    </button>
  </div>

  <footer>O jogo busca essas mudanças automaticamente, em até 1 minuto.</footer>
</div>

<script>
// ===================== ESTADO =====================
let cfg = { owner:'Adrielzinho60', repo:'Ludo-Das-Emo-es-', branch:'main', token:'' };
let data = { curiosidades: [], perguntas: [], removidas: [] };
let currentSha = null; // sha do arquivo no GitHub, null = ainda não existe

const CFG_KEY = 'ludoAdminConfigV1';

function carregarConfigSalva(){
  try{
    const raw = localStorage.getItem(CFG_KEY);
    if(raw) cfg = { ...cfg, ...JSON.parse(raw) };
  }catch(e){}
  document.getElementById('cfgOwner').value = cfg.owner || '';
  document.getElementById('cfgRepo').value = cfg.repo || '';
  document.getElementById('cfgBranch').value = cfg.branch || 'main';
  document.getElementById('cfgToken').value = cfg.token || '';
  if(cfg.owner && cfg.repo && cfg.token){
    document.getElementById('settingsCard').open = false;
  } else {
    document.getElementById('settingsCard').open = true;
  }
}

function salvarConfig(){
  cfg.owner = document.getElementById('cfgOwner').value.trim();
  cfg.repo = document.getElementById('cfgRepo').value.trim();
  cfg.branch = document.getElementById('cfgBranch').value.trim() || 'main';
  cfg.token = document.getElementById('cfgToken').value.trim();
  try{ localStorage.setItem(CFG_KEY, JSON.stringify(cfg)); }catch(e){}
  toast('Configuração salva neste navegador.', 'ok');
  carregarDoGitHub();
}

function limparConfig(){
  try{ localStorage.removeItem(CFG_KEY); }catch(e){}
  cfg = { owner:'', repo:'', branch:'main', token:'' };
  carregarConfigSalva();
  setStatus(false, 'Configuração limpa.');
}

// ===================== GITHUB API =====================
function apiUrl(){
  return `https://api.github.com/repos/${cfg.owner}/${cfg.repo}/contents/dados.json`;
}

function b64EncodeUnicode(str){
  return btoa(encodeURIComponent(str).replace(/%([0-9A-F]{2})/g, (m,p1)=> String.fromCharCode('0x'+p1)));
}
function b64DecodeUnicode(str){
  return decodeURIComponent(atob(str).split('').map(c => '%' + ('00'+c.charCodeAt(0).toString(16)).slice(-2)).join(''));
}

async function carregarDoGitHub(){
  if(!cfg.owner || !cfg.repo || !cfg.token){ setStatus(false, 'Preencha a configuração do repositório.'); return; }
  setStatus(null, 'Conectando ao GitHub…');
  try{
    const resp = await fetch(apiUrl() + '?ref=' + encodeURIComponent(cfg.branch), {
      headers: { Authorization: 'Bearer ' + cfg.token, Accept: 'application/vnd.github+json' }
    });
    if(resp.status === 404){
      // arquivo ainda não existe — começa do zero
      data = { curiosidades: [], perguntas: [], removidas: [] };
      currentSha = null;
      setStatus(true, 'Conectado. Nenhuma atualização publicada ainda.');
      renderAll();
      return;
    }
    if(!resp.ok) throw new Error('GitHub respondeu ' + resp.status);
    const json = await resp.json();
    currentSha = json.sha;
    const conteudo = b64DecodeUnicode(json.content.replace(/\n/g,''));
    data = JSON.parse(conteudo || '{}');
    data.curiosidades = data.curiosidades || [];
    data.perguntas = data.perguntas || [];
    data.removidas = data.removidas || [];
    setStatus(true, 'Conectado a ' + cfg.owner + '/' + cfg.repo);
    renderAll();
  }catch(e){
    setStatus(false, 'Não consegui conectar — confira usuário, repositório e token.');
  }
}

async function publicar(){
  if(!cfg.owner || !cfg.repo || !cfg.token){ toast('Configure o repositório primeiro.', 'err'); document.getElementById('settingsCard').open = true; return; }
  const btn = document.getElementById('publishBtn');
  const spin = document.getElementById('publishSpin');
  const label = document.getElementById('publishLabel');
  btn.disabled = true; spin.classList.add('show'); label.textContent = 'Publicando…';
  try{
    const body = {
      message: 'Atualiza conteúdo via painel',
      content: b64EncodeUnicode(JSON.stringify(data, null, 2)),
      branch: cfg.branch
    };
    if(currentSha) body.sha = currentSha;
    const resp = await fetch(apiUrl(), {
      method: 'PUT',
      headers: { Authorization: 'Bearer ' + cfg.token, 'Content-Type': 'application/json', Accept: 'application/vnd.github+json' },
      body: JSON.stringify(body)
    });
    if(!resp.ok){
      const errBody = await resp.text();
      throw new Error('GitHub respondeu ' + resp.status + ': ' + errBody.slice(0,140));
    }
    const json = await resp.json();
    currentSha = json.content.sha;
    label.textContent = '✓ Publicado!';
    toast('Publicado! O jogo recebe isso em até 1 minuto.', 'ok');
    setTimeout(()=>{ label.textContent = '🚀 Publicar atualização'; }, 2200);
  }catch(e){
    label.textContent = '🚀 Publicar atualização';
    toast('Erro ao publicar: ' + e.message, 'err');
  }finally{
    btn.disabled = false; spin.classList.remove('show');
  }
}

// ===================== UI: STATUS / TOAST =====================
function setStatus(ok, text){
  const dot = document.getElementById('statusDot');
  dot.className = 'status-dot' + (ok===true ? ' ok' : ok===false ? ' err' : '');
  document.getElementById('statusText').textContent = text;
}
function toast(msg, type){
  const area = document.getElementById('toastArea');
  const el = document.createElement('div');
  el.className = 'toast ' + (type||'');
  el.textContent = msg;
  area.appendChild(el);
  setTimeout(()=> el.remove(), 3000);
}

// ===================== TABS =====================
function initTabs(){
  const tabs = Array.from(document.querySelectorAll('.tab'));
  const indicator = document.getElementById('tabIndicator');
  function moveIndicator(tabEl){
    indicator.style.left = tabEl.offsetLeft + 'px';
    indicator.style.width = tabEl.offsetWidth + 'px';
  }
  tabs.forEach(t => t.addEventListener('click', () => {
    tabs.forEach(o=>o.classList.remove('active'));
    t.classList.add('active');
    moveIndicator(t);
    document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
    document.getElementById('panel-' + t.dataset.tab).classList.add('active');
  }));
  requestAnimationFrame(()=> moveIndicator(tabs[0]));
  window.addEventListener('resize', ()=>{
    const active = document.querySelector('.tab.active');
    if(active) moveIndicator(active);
  });
}

// ===================== FORMS =====================
let correctChoice = null;
document.getElementById('correctRow').addEventListener('click', (e)=>{
  const chip = e.target.closest('.correct-chip');
  if(!chip) return;
  document.querySelectorAll('.correct-chip').forEach(c=>c.classList.remove('sel'));
  chip.classList.add('sel');
  correctChoice = Number(chip.dataset.c);
});

function addCuriosidade(){
  const el = document.getElementById('novaCuriosidade');
  const txt = el.value.trim();
  if(!txt) { toast('Escreva alguma coisa antes de adicionar.', 'err'); return; }
  data.curiosidades.push(txt);
  el.value = '';
  renderCuriosidades();
  toast('Curiosidade adicionada à lista (ainda não publicada).', 'ok');
}

function addPergunta(){
  const q = document.getElementById('novaPergunta').value.trim();
  const a = ['op1','op2','op3','op4'].map(id=>document.getElementById(id).value.trim());
  if(!q || a.some(x=>!x) || correctChoice===null){
    toast('Preencha a pergunta, as 4 opções e marque a correta.', 'err');
    return;
  }
  data.perguntas.push({ q, a, c: correctChoice });
  document.getElementById('novaPergunta').value = '';
  ['op1','op2','op3','op4'].forEach(id=> document.getElementById(id).value = '');
  document.querySelectorAll('.correct-chip').forEach(c=>c.classList.remove('sel'));
  correctChoice = null;
  renderPerguntas();
  toast('Pergunta adicionada à lista (ainda não publicada).', 'ok');
}

function addRemovida(){
  const el = document.getElementById('novaRemovida');
  const txt = el.value.trim();
  if(!txt){ toast('Cole o texto exato a esconder.', 'err'); return; }
  if(!data.removidas.includes(txt)) data.removidas.push(txt);
  el.value = '';
  renderRemovidas();
  toast('Adicionado à lista de itens escondidos.', 'ok');
}

function removerItem(lista, idx, renderFn){
  const boxId = lista==='curiosidades' ? 'listCuriosidades' : lista==='perguntas' ? 'listPerguntas' : 'listRemovidas';
  const el = document.querySelectorAll(`#${boxId} .item`)[idx];
  if(el){
    el.classList.add('removing');
    setTimeout(()=>{ data[lista].splice(idx,1); renderFn(); }, 220);
  } else {
    data[lista].splice(idx,1); renderFn();
  }
}

// ===================== RENDER =====================
function esc(s){ const d=document.createElement('div'); d.textContent = s; return d.innerHTML; }

function renderCuriosidades(){
  const box = document.getElementById('listCuriosidades');
  document.getElementById('countCurio').textContent = data.curiosidades.length;
  if(data.curiosidades.length===0){ box.innerHTML = '<div class="empty-hint">Nenhuma curiosidade extra ainda.</div>'; return; }
  box.innerHTML = data.curiosidades.map((c,i)=>`
    <div class="item">
      <div class="txt">${esc(c)}</div>
      <button class="btn btn-danger" onclick="removerItem('curiosidades',${i},renderCuriosidades)">Remover</button>
    </div>
  `).join('');
}

function renderPerguntas(){
  const box = document.getElementById('listPerguntas');
  document.getElementById('countQuest').textContent = data.perguntas.length;
  if(data.perguntas.length===0){ box.innerHTML = '<div class="empty-hint">Nenhuma pergunta extra ainda.</div>'; return; }
  box.innerHTML = data.perguntas.map((p,i)=>`
    <div class="item">
      <div class="txt">${esc(p.q)}<small>Correta: ${esc(p.a[p.c] || '?')}</small></div>
      <button class="btn btn-danger" onclick="removerItem('perguntas',${i},renderPerguntas)">Remover</button>
    </div>
  `).join('');
}

function renderRemovidas(){
  const box = document.getElementById('listRemovidas');
  document.getElementById('countRem').textContent = data.removidas.length;
  if(data.removidas.length===0){ box.innerHTML = '<div class="empty-hint">Nada escondido por enquanto.</div>'; return; }
  box.innerHTML = data.removidas.map((t,i)=>`
    <div class="item">
      <div class="txt">${esc(t)}</div>
      <button class="btn btn-danger" onclick="removerItem('removidas',${i},renderRemovidas)">Remover</button>
    </div>
  `).join('');
}

function renderAll(){ renderCuriosidades(); renderPerguntas(); renderRemovidas(); }

// ===================== INIT =====================
initTabs();
carregarConfigSalva();
if(cfg.owner && cfg.repo && cfg.token) carregarDoGitHub();
else setStatus(false, 'Preencha a configuração do repositório para começar.');
</script>
</body>
</html>