<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Ludo das Emoções</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', system-ui, sans-serif; }
  body { min-height: 100vh; background: linear-gradient(135deg,#1a1a3e,#2d1b4e,#1a1a3e); color:#fff; overflow-x:hidden; }
  .screen { display:none; min-height:100vh; padding:20px; }
  .screen.active { display:flex; flex-direction:column; align-items:center; justify-content:center; }
  h1 { font-size:clamp(2rem,6vw,3.5rem); background:linear-gradient(90deg,#ff6b6b,#feca57,#48dbfb,#1dd1a1); -webkit-background-clip:text; background-clip:text; color:transparent; margin-bottom:10px; text-align:center; }
  .subtitle { color:#a0a0c0; margin-bottom:40px; text-align:center; }
  .menu-btns { display:flex; flex-direction:column; gap:16px; width:100%; max-width:320px; }
  .menu-btn { padding:18px; font-size:1.1rem; border:none; border-radius:14px; background:linear-gradient(135deg,#6c5ce7,#a29bfe); color:#fff; font-weight:600; cursor:pointer; transition:transform .15s, box-shadow .15s; box-shadow:0 4px 20px rgba(108,92,231,.4); }
  .menu-btn:hover { transform:translateY(-2px); box-shadow:0 6px 28px rgba(108,92,231,.6); }

  /* Game screen */
  #gameScreen { padding:10px; }
  .game-top { display:flex; justify-content:space-between; align-items:center; width:100%; max-width:900px; margin-bottom:10px; }
  .game-top h2 { font-size:1.2rem; }
  .reset-btn { background:#ff6b6b; border:none; color:#fff; padding:8px 14px; border-radius:8px; cursor:pointer; font-weight:600; }

  .board { display:grid; grid-template-columns:repeat(6,1fr); gap:6px; width:100%; max-width:600px; aspect-ratio:1; background:rgba(255,255,255,.05); padding:10px; border-radius:16px; margin:10px auto; }
  .cell { background:linear-gradient(135deg,#2d3561,#3d4574); border-radius:8px; position:relative; display:flex; align-items:center; justify-content:center; font-size:.75rem; font-weight:700; color:rgba(255,255,255,.55); padding:2px; min-height:0; }
  .cell.start { background:linear-gradient(135deg,#1dd1a1,#10ac84); color:#fff; }
  .cell.end { background:linear-gradient(135deg,#feca57,#ff9f43); color:#fff; }
  .cell .num { position:absolute; top:2px; left:4px; font-size:.65rem; opacity:.7; }
  .pawns { display:flex; flex-wrap:wrap; gap:2px; align-items:center; justify-content:center; }
  .pawn { width:14px; height:14px; border-radius:50%; border:2px solid #fff; box-shadow:0 2px 4px rgba(0,0,0,.4); }

  .players-panel { display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); gap:10px; width:100%; max-width:600px; margin:10px auto; }
  .player-card { background:rgba(255,255,255,.07); padding:12px; border-radius:12px; display:flex; flex-direction:column; align-items:center; gap:8px; border:2px solid transparent; transition:.2s; }
  .player-card.active { border-color:#feca57; box-shadow:0 0 20px rgba(254,202,87,.4); transform:scale(1.03); }
  .player-info { display:flex; align-items:center; gap:8px; }
  .player-info .dot { width:18px; height:18px; border-radius:50%; border:2px solid #fff; }
  .player-info span { font-weight:600; font-size:.9rem; }
  .player-pos { font-size:.8rem; color:#a0a0c0; }
  .roll-btn { padding:10px 16px; border:none; border-radius:10px; background:linear-gradient(135deg,#48dbfb,#0abde3); color:#fff; font-weight:700; cursor:pointer; width:100%; font-size:.95rem; }
  .roll-btn:disabled { opacity:.4; cursor:not-allowed; }

  .dice-box { display:flex; justify-content:center; align-items:center; margin:8px auto; }
  #diceCanvas { width:180px; height:180px; display:block; background:transparent; }

  .status { text-align:center; margin:10px; min-height:24px; font-weight:600; }

  /* Modal */
  .modal-bg { display:none; position:fixed; inset:0; background:rgba(0,0,0,.75); z-index:100; align-items:center; justify-content:center; padding:20px; }
  .modal-bg.show { display:flex; }
  .modal { background:linear-gradient(135deg,#2d1b4e,#3d2b5e); padding:24px; border-radius:18px; max-width:480px; width:100%; box-shadow:0 20px 60px rgba(0,0,0,.6); border:2px solid rgba(255,255,255,.1); }
  .modal h3 { margin-bottom:12px; font-size:1.3rem; }
  .modal p { margin-bottom:18px; line-height:1.5; color:#e0e0f0; }
  .modal .answers { display:flex; flex-direction:column; gap:8px; margin-bottom:14px; }
  .modal .answers button { padding:12px; border:1px solid rgba(255,255,255,.2); background:rgba(255,255,255,.06); color:#fff; border-radius:10px; cursor:pointer; text-align:left; transition:.15s; }
  .modal .answers button:hover { background:rgba(255,255,255,.14); }
  .modal .close-btn { padding:12px 20px; border:none; border-radius:10px; background:linear-gradient(135deg,#1dd1a1,#10ac84); color:#fff; font-weight:700; cursor:pointer; width:100%; }
  .modal .badge { display:inline-block; padding:4px 10px; border-radius:20px; font-size:.75rem; font-weight:700; margin-bottom:10px; }
  .badge.curio { background:#48dbfb; color:#1a1a3e; }
  .badge.quest { background:#feca57; color:#1a1a3e; }
  .feedback { padding:12px; border-radius:10px; margin-bottom:14px; font-weight:600; text-align:center; }
  .feedback.ok { background:rgba(29,209,161,.2); color:#1dd1a1; }
  .feedback.bad { background:rgba(255,107,107,.2); color:#ff6b6b; }

  @media (max-width:500px){
    .board { gap:3px; padding:6px; }
    .cell { font-size:.6rem; }
    .pawn { width:10px; height:10px; border-width:1.5px; }
  }

  /* Banner de atualização (estilo Play Store) */
  #updateBanner { position:fixed; top:0; left:0; right:0; z-index:200; display:none;
    background:linear-gradient(90deg,#1dd1a1,#10ac84); color:#fff; padding:10px 14px;
    font-weight:600; box-shadow:0 4px 16px rgba(0,0,0,.4);
    align-items:center; justify-content:space-between; gap:12px; font-size:.9rem; }
  #updateBanner.show { display:flex; }
  #updateBanner .info { display:flex; flex-direction:column; line-height:1.2; }
  #updateBanner .info small { opacity:.85; font-weight:500; }
  #updateBanner button { background:#fff; color:#10ac84; border:none; padding:8px 14px;
    border-radius:8px; font-weight:700; cursor:pointer; white-space:nowrap; }
  #updateBanner .dismiss { background:transparent; color:#fff; border:1px solid rgba(255,255,255,.5); }
  #versionTag { position:fixed; bottom:6px; right:8px; font-size:.65rem; color:rgba(255,255,255,.35); z-index:50; }
</style>
</head>
