<!-- Banner de atualização tipo Play Store (versão do JOGO) -->
<div id="updateBanner">
  <div class="info">
    <span>🔄 Nova versão disponível!</span>
    <small id="updateNotes">Clique em Atualizar para baixar a última versão.</small>
  </div>
  <div style="display:flex; gap:8px;">
    <button class="dismiss" onclick="document.getElementById('updateBanner').classList.remove('show')">Depois</button>
    <button onclick="window.applyUpdate()">Atualizar</button>
  </div>
</div>
<div id="versionTag">v<span id="vNow">?</span></div>

<!-- TELA 1: SELEÇÃO -->
<div class="screen active" id="menuScreen">
  <h1>Ludo das Emoções</h1>
  <p class="subtitle">Escolha o número de jogadores</p>
  <div class="menu-btns">
    <button class="menu-btn" onclick="startGame(1)">1 Jogador</button>
