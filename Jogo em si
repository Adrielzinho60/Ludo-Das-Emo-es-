  { q: "Saudade é uma emoção...", a:["Pura tristeza","Mista de alegria e tristeza","Raiva","Medo"], c:1 },
  { q: "Qual prática reduz crises de pânico ao focar no corpo?", a:["Comer","Ouvir o coração bater","Correr","Falar alto"], c:1 },
  { q: "O famoso 'borboletas no estômago' é resultado de...", a:["Fome","Adrenalina pausando a digestão","Sede","Excesso de açúcar"], c:1 },
  { q: "Casais que riem juntos tendem a...", a:["Durar menos","Durar mais","Discutir mais","Não mudar nada"], c:1 },
  { q: "Pessoas que pedem ajuda são vistas geralmente como...", a:["Fracas","Mais competentes","Iguais","Egoístas"], c:1 },
  { q: "O choro de alegria serve para...", a:["Esvaziar lágrimas","Equilibrar emoção intensa","Disfarçar dor","Atrair atenção"], c:1 },
  { q: "Animais de estimação ajudam a reduzir...", a:["Vitamina D","Cortisol (estresse)","Visão","Peso"], c:1 },
  { q: "Ouvir 'eu te entendo' acalma o sistema nervoso em...", a:["Horas","Minutos","Segundos","Dias"], c:2 }
];

// ============== ESTADO ==============
let state = null;
const COLORS = ["#ff6b6b","#48dbfb","#1dd1a1","#feca57"];
const NAMES = ["Vermelho","Azul","Verde","Amarelo"];
const TOTAL_CELLS = 30;

function startGame(n){
  state = {
    nPlayers: n,
    positions: Array(n).fill(0),
    current: 0,
    rolling: false,
    usedCurios: new Set(),
    usedQuests: new Set(),
    cellTypes: [] // per cell: 'curio' | 'quest' | null
  };
  // espalhar perguntas/curiosidades nas casas (1..29). Casa 0 = início, 29 = chegada
  const indices = Array.from({length: TOTAL_CELLS-2}, (_,i)=>i+1);
  shuffle(indices);
  state.cellTypes = Array(TOTAL_CELLS).fill(null);
  // 12 perguntas e 16 curiosidades distribuídas (28 casas intermediárias)
  indices.slice(0,12).forEach(i=> state.cellTypes[i]='quest');
  indices.slice(12,28).forEach(i=> state.cellTypes[i]='curio');

  document.getElementById('menuScreen').classList.remove('active');
  document.getElementById('gameScreen').classList.add('active');
  renderBoard(); renderPlayers(); updateStatus();
}

function backToMenu(){
  document.getElementById('gameScreen').classList.remove('active');
  document.getElementById('menuScreen').classList.add('active');
  closeModal();
}

function shuffle(a){ for(let i=a.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); [a[i],a[j]]=[a[j],a[i]]; } }

function renderBoard(){
  const b = document.getElementById('board');
  b.innerHTML = '';
  for(let i=0;i<TOTAL_CELLS;i++){
    const c = document.createElement('div');
    c.className = 'cell' + (i===0?' start':'') + (i===TOTAL_CELLS-1?' end':'');
    let label = '';
    if(i===0) label = 'INÍCIO';
    else if(i===TOTAL_CELLS-1) label = 'FIM';
    else if(state.cellTypes[i]==='quest') label = '❓';
    else if(state.cellTypes[i]==='curio') label = '💡';
    c.innerHTML = `<span class="num">${i}</span><div class="pawns" id="cell-${i}"></div><div style="font-size:.7rem">${label}</div>`;
    b.appendChild(c);
  }
  drawPawns();
}

function drawPawns(){
  for(let i=0;i<TOTAL_CELLS;i++){
    const el = document.getElementById('cell-'+i);
    if(el) el.innerHTML='';
  }
  state.positions.forEach((pos, idx)=>{
    const el = document.getElementById('cell-'+pos);
    if(el){
      const p = document.createElement('div');
      p.className='pawn';
      p.style.background = COLORS[idx];
      el.appendChild(p);
    }
  });
}

function renderPlayers(){
  const panel = document.getElementById('playersPanel');
  panel.innerHTML='';
  for(let i=0;i<state.nPlayers;i++){
    const card = document.createElement('div');
    card.className = 'player-card' + (i===state.current?' active':'');
    card.innerHTML = `
      <div class="player-info">
        <span class="dot" style="background:${COLORS[i]}"></span>
        <span>Jogador ${i+1} (${NAMES[i]})</span>
      </div>
      <div class="player-pos">Casa: ${state.positions[i]} / ${TOTAL_CELLS-1}</div>
      <button class="roll-btn" onclick="rollDice(${i})" ${i===state.current && !state.rolling ? '' : 'disabled'}>🎲 Rolar</button>
    `;
    panel.appendChild(card);
  }
}

function updateStatus(msg){
  document.getElementById('status').textContent = msg || `Vez do Jogador ${state.current+1} (${NAMES[state.current]})`;
}

async function rollDice(playerIdx){
  if(state.rolling || playerIdx!==state.current) return;
  state.rolling = true;
  renderPlayers();
  const val = await window.rollDice3D();
  movePlayer(playerIdx, val);
}

function movePlayer(idx, steps){
  let target = state.positions[idx] + steps;
  if(target > TOTAL_CELLS-1) target = TOTAL_CELLS-1;
  state.positions[idx] = target;
  drawPawns();
  renderPlayers();

  if(target === TOTAL_CELLS-1){
    setTimeout(()=> showWin(idx), 400);
    return;
  }

  const type = state.cellTypes[target];
  if(type==='curio') setTimeout(()=> showCuriosidade(), 350);
  else if(type==='quest') setTimeout(()=> showPergunta(), 350);
  else nextTurn();
}

function showCuriosidade(){
  let pool = CURIOSIDADES.map((_,i)=>i).filter(i=>!state.usedCurios.has(i));
  if(pool.length===0){ state.usedCurios.clear(); pool = CURIOSIDADES.map((_,i)=>i); }
  const idx = pool[Math.floor(Math.random()*pool.length)];
  state.usedCurios.add(idx);
  openModal(`
    <span class="badge curio">💡 Curiosidade</span>
    <h3>Você sabia?</h3>
    <p>${CURIOSIDADES[idx]}</p>
    <button class="close-btn" onclick="closeAndNext()">Continuar</button>
  `);
}

let _lastQuestion = null;

function showPergunta(){
  let pool = PERGUNTAS.map((_,i)=>i).filter(i=>!state.usedQuests.has(i));
  if(pool.length===0){ state.usedQuests.clear(); pool = PERGUNTAS.map((_,i)=>i); }
  const idx = pool[Math.floor(Math.random()*pool.length)];
  state.usedQuests.add(idx);
  const p = PERGUNTAS[idx];
  _lastQuestion = p;
  const btns = p.a.map((ans,i)=>`<button onclick="answerQuestion(${i},${p.c})">${ans}</button>`).join('');
  openModal(`
    <span class="badge quest">❓ Pergunta</span>
    <h3>${p.q}</h3>
    <div class="answers">${btns}</div>
  `);
}

function answerQuestion(chosen, correct){
  const ok = chosen===correct;
  const msg = ok ? '✅ Você acertou!' : '❌ Você errou!';
  const cls = ok ? 'ok' : 'bad';
  const respostaCorreta = _lastQuestion ? _lastQuestion.a[correct] : '';
  openModal(`
    <span class="badge quest">❓ Resultado</span>
    <div class="feedback ${cls}">${msg}</div>
    <p style="text-align:center">Resposta correta: <b>${respostaCorreta}</b></p>
    <button class="close-btn" onclick="closeAndNext()">Continuar</button>
  `);
}

function closeAndNext(){ closeModal(); nextTurn(); }

function nextTurn(){
  state.current = (state.current + 1) % state.nPlayers;
  state.rolling = false;
  renderPlayers();
  updateStatus();
}

function showWin(idx){
  openModal(`
    <span class="badge curio">🏆 Vitória!</span>
    <h3>Jogador ${idx+1} (${NAMES[idx]}) venceu!</h3>
    <p>Parabéns! Você chegou à casa final do Ludo das Emoções.</p>
    <button class="close-btn" onclick="closeModal(); backToMenu();">Voltar ao Menu</button>
  `);
}

function openModal(html){
  document.getElementById('modal').innerHTML = html;
  document.getElementById('modalBg').classList.add('show');
}
function closeModal(){ document.getElementById('modalBg').classList.remove('show'); }
</script>

<!-- ====== CONTEÚDO EXTRA (publicado pelo admin.html no seu GitHub) ======
  - As 150 curiosidades e 40 perguntas acima continuam sendo a base fixa, sempre presente.
  - O conteúdo extra mora em um arquivo público (dados.json) no seu repositório GitHub.
    O JOGO NÃO USA NENHUM TOKEN — é leitura pública, segura pra deixar no código.
  - Quem publica atualizações é você, pelo admin.html, no seu navegador (só aí entra o token).
  - O jogo busca esse arquivo, junta com a base fixa (escondendo o que estiver na lista de
    "removidas"), guarda em cache local e funciona offline depois da primeira vez.
  - Se o arquivo ainda não existir no GitHub (você não publicou nada ainda), o jogo
    simplesmente ignora e segue só com a base fixa — sem erro, sem travar.
-->
<script>
const DATA_URL = 'https://raw.githubusercontent.com/Adrielzinho60/Ludo-Das-Emo-es-/main/dados.json';
const CONTENT_SYNC_INTERVAL_MS = 60000; // 60s — separado do checador de versão do jogo (30s)
const CONTENT_CACHE_KEY = 'ludoConteudoExtraV1';

// Cópia intocada da base fixa, usada pra poder filtrar "removidas" sem perder o original
const CURIOSIDADES_BASE = CURIOSIDADES.slice();
const PERGUNTAS_BASE = PERGUNTAS.slice();

function aplicarConteudoExtra(extra){
  const removidos = new Set((extra.removidas || []).map(t => String(t).trim().toLowerCase()));
  const curiosFiltradas = CURIOSIDADES_BASE.filter(c => !removidos.has(c.trim().toLowerCase()));
  const perguntasFiltradas = PERGUNTAS_BASE.filter(p => !removidos.has(p.q.trim().toLowerCase()));

  CURIOSIDADES.length = 0;
  CURIOSIDADES.push(...curiosFiltradas, ...(extra.curiosidades || []));
  PERGUNTAS.length = 0;
  PERGUNTAS.push(...perguntasFiltradas, ...(extra.perguntas || []));
}

async function sincronizarConteudo(){
  let cache = null;
  try { cache = localStorage.getItem(CONTENT_CACHE_KEY); } catch(e){}
  if(cache){
    try { aplicarConteudoExtra(JSON.parse(cache)); } catch(e){}
  }

  if(!navigator.onLine) return;
  try{
    const resp = await fetch(DATA_URL + '?t=' + Date.now(), { cache: 'no-store' });
    if(!resp.ok) return; // arquivo ainda não existe ou link errado — segue só com a base fixa
    const extra = await resp.json();
    aplicarConteudoExtra(extra);
    try { localStorage.setItem(CONTENT_CACHE_KEY, JSON.stringify(extra)); } catch(e){}
  }catch(e){
    console.log('Conteúdo extra: sem conexão agora, usando o que já tem salvo.');
  }
}

sincronizarConteudo();
setInterval(sincronizarConteudo, CONTENT_SYNC_INTERVAL_MS);
window.addEventListener('online', sincronizarConteudo);
</script>

<!-- ====== DADO 3D COM FÍSICA (Three.js + cannon-es) ====== -->
<script type="importmap">
{
  "imports": {
    "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
    "cannon-es": "https://unpkg.com/cannon-es@0.20.0/dist/cannon-es.js"
  }
}
</script>
<script type="module">
import * as THREE from 'three';
import * as CANNON from 'cannon-es';

const canvas = document.getElementById('diceCanvas');
const W = 360, H = 360;

const renderer = new THREE.WebGLRenderer({ canvas, antialias:true, alpha:true });
renderer.setPixelRatio(window.devicePixelRatio);
renderer.setSize(W, H, false);
renderer.shadowMap.enabled = true;

const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(35, 1, 0.1, 100);
camera.position.set(0, 9, 0.01);
camera.lookAt(0,0,0);

scene.add(new THREE.AmbientLight(0xffffff, 0.6));
const dir = new THREE.DirectionalLight(0xffffff, 0.9);
dir.position.set(5,10,5); dir.castShadow = true;
dir.shadow.mapSize.set(1024,1024);
scene.add(dir);

const floorGeo = new THREE.PlaneGeometry(20,20);
const floorMat = new THREE.ShadowMaterial({ opacity:0.25 });
const floor = new THREE.Mesh(floorGeo, floorMat);
floor.rotation.x = -Math.PI/2; floor.receiveShadow = true;
scene.add(floor);

function pipTexture(n){
  const s = 256;
  const c = document.createElement('canvas'); c.width=c.height=s;
  const ctx = c.getContext('2d');
  ctx.fillStyle = '#fafafa'; ctx.fillRect(0,0,s,s);
  ctx.strokeStyle = '#d0d0d8'; ctx.lineWidth = 8; ctx.strokeRect(4,4,s-8,s-8);
  ctx.fillStyle = '#1a1a3e';
  const r = 22;
  const pos = {
    1:[[.5,.5]],
    2:[[.28,.28],[.72,.72]],
    3:[[.25,.25],[.5,.5],[.75,.75]],
    4:[[.28,.28],[.72,.28],[.28,.72],[.72,.72]],
    5:[[.25,.25],[.75,.25],[.5,.5],[.25,.75],[.75,.75]],
    6:[[.28,.22],[.72,.22],[.28,.5],[.72,.5],[.28,.78],[.72,.78]]
  }[n];
  pos.forEach(([x,y])=>{
    ctx.beginPath(); ctx.arc(x*s, y*s, r, 0, Math.PI*2); ctx.fill();
  });
  const t = new THREE.CanvasTexture(c);
  t.anisotropy = 4;
  return t;
}

const faceVals = [3, 4, 1, 6, 2, 5]; // +X,-X,+Y,-Y,+Z,-Z (opostas somam 7)
const materials = faceVals.map(v => new THREE.MeshStandardMaterial({ map: pipTexture(v), roughness:0.4, metalness:0.1 }));

const size = 1.2;
const dieGeo = new THREE.BoxGeometry(size, size, size);
const die = new THREE.Mesh(dieGeo, materials);
die.castShadow = true;
scene.add(die);

const world = new CANNON.World({ gravity: new CANNON.Vec3(0,-30,0) });
world.defaultContactMaterial.restitution = 0.3;
world.defaultContactMaterial.friction = 0.4;

const groundBody = new CANNON.Body({ mass:0, shape:new CANNON.Plane() });
groundBody.quaternion.setFromAxisAngle(new CANNON.Vec3(1,0,0), -Math.PI/2);
world.addBody(groundBody);

const wallShape = new CANNON.Plane();
const walls = [
  { pos:[0,0,-3], axis:[0,1,0], ang:0 },
  { pos:[0,0,3],  axis:[0,1,0], ang:Math.PI },
  { pos:[-3,0,0], axis:[0,1,0], ang:Math.PI/2 },
  { pos:[3,0,0],  axis:[0,1,0], ang:-Math.PI/2 },
];
walls.forEach(w=>{
  const b = new CANNON.Body({ mass:0, shape:wallShape });
  b.position.set(...w.pos);
  b.quaternion.setFromAxisAngle(new CANNON.Vec3(...w.axis), w.ang);
  world.addBody(b);
});

const dieBody = new CANNON.Body({
  mass: 1,
  shape: new CANNON.Box(new CANNON.Vec3(size/2, size/2, size/2)),
  angularDamping: 0.1, linearDamping: 0.1,
});
dieBody.position.set(0, 3, 0);
world.addBody(dieBody);

let rolling = false;
let resolveRoll = null;
let settleTicks = 0;

function getTopFaceValue(){
  const up = new THREE.Vector3(0,1,0);
  const axes = [
    new THREE.Vector3(1,0,0), new THREE.Vector3(-1,0,0),
    new THREE.Vector3(0,1,0), new THREE.Vector3(0,-1,0),
    new THREE.Vector3(0,0,1), new THREE.Vector3(0,0,-1),
  ];
  let best = -2, idx = 0;
  axes.forEach((a,i)=>{
    const v = a.clone().applyQuaternion(die.quaternion);
    const d = v.dot(up);
    if(d>best){ best=d; idx=i; }
  });
  return faceVals[idx];
}

window.rollDice3D = function(){
  return new Promise((resolve)=>{
    rolling = true; settleTicks = 0; resolveRoll = resolve;
    dieBody.position.set((Math.random()-0.5)*1.5, 4, (Math.random()-0.5)*1.5);
    dieBody.velocity.set((Math.random()-0.5)*6, -2, (Math.random()-0.5)*6);
    dieBody.angularVelocity.set(
      (Math.random()-0.5)*20,
      (Math.random()-0.5)*20,
      (Math.random()-0.5)*20
    );
    dieBody.quaternion.setFromEuler(Math.random()*Math.PI, Math.random()*Math.PI, Math.random()*Math.PI);
  });
};

const clock = new THREE.Clock();
function animate(){
  requestAnimationFrame(animate);
  const dt = Math.min(clock.getDelta(), 1/30);
  if(rolling){
    world.step(1/60, dt, 3);
    die.position.copy(dieBody.position);
    die.quaternion.copy(dieBody.quaternion);
    const speed = dieBody.velocity.length() + dieBody.angularVelocity.length();
    if(speed < 0.15){ settleTicks++; } else { settleTicks = 0; }
    if(settleTicks > 25){
      rolling = false;
      const v = getTopFaceValue();
      if(resolveRoll){ const r = resolveRoll; resolveRoll = null; setTimeout(()=>r(v), 250); }
    }
  } else {
    die.rotation.x += dt*0.4;
    die.rotation.y += dt*0.5;
    die.position.set(0,0.6 + Math.sin(performance.now()/600)*0.05, 0);
  }
  renderer.render(scene, camera);
}
animate();
</script>

<!-- ====== SISTEMA DE ATUALIZAÇÃO DO JOGO (estilo Play Store) ====== -->
<!--
  Atenção: isso atualiza a VERSÃO DO JOGO (código), não as curiosidades/
  perguntas, que agora estão fixas aqui dentro do HTML.
  - Se aberto LOCALMENTE (file://) e sem internet → tudo offline, sem banner, sem erro.
  - Se houver internet → consulta ludo-version.json a cada 30s no servidor abaixo.
  - Quando sair uma versão nova, aparece o banner verde no topo.
-->
<script>
(function(){
  const UPDATE_SERVER = 'https://project--6317c82f-a0bc-4494-88c4-624071cc1e03-dev.lovable.app';
  const VERSION_URL   = UPDATE_SERVER + '/ludo-version.json';
  const DOWNLOAD_URL  = UPDATE_SERVER + '/ludo.html';
  const STORAGE_KEY   = 'ludo_installed_version';
  const CHECK_INTERVAL_MS = 30000;
  const isLocal = location.protocol === 'file:';

  let installed = null;
  try { installed = localStorage.getItem(STORAGE_KEY); } catch(e){}
  let latest = null;

  function showVersion(v){ const el=document.getElementById('vNow'); if(el) el.textContent = v || 'local'; }
  showVersion(installed);

  async function fetchManifest(){
    if(!navigator.onLine) return null;
    try {
      const r = await fetch(VERSION_URL + '?t=' + Date.now(), { cache:'no-store', mode:'cors' });
      if(!r.ok) return null;
      return await r.json();
    } catch(e){ return null; }
  }

  function showBanner(notes){
    const b = document.getElementById('updateBanner');
    const n = document.getElementById('updateNotes');
    if(notes && n) n.textContent = notes;
    if(b) b.classList.add('show');
  }

  window.applyUpdate = function(){
    if(latest && latest.version){
      try { localStorage.setItem(STORAGE_KEY, latest.version); } catch(e){}
    }
    if(isLocal){
      window.open(DOWNLOAD_URL, '_blank');
      const b = document.getElementById('updateBanner');
      if(b) b.classList.remove('show');
      alert('Baixe o novo ludo.html e substitua o arquivo local. Depois abra de novo.');
    } else {
      const url = new URL(window.location.href);
      url.searchParams.set('v', (latest && latest.version) || Date.now());
      window.location.replace(url.toString());
    }
  };

  async function check(){
    const m = await fetchManifest();
    if(!m || !m.version) return;
    latest = m;
    if(!installed){
      installed = m.version;
      try { localStorage.setItem(STORAGE_KEY, m.version); } catch(e){}
      showVersion(installed);
      return;
    }
    if(m.version !== installed){
      showBanner(m.notes || ('Versão ' + m.version + ' disponível.'));
    }
  }

  check();
  setInterval(check, CHECK_INTERVAL_MS);
  window.addEventListener('online', check);
})();
</script>
